{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto-Setup Python Environment",
      "type": "shell",
      "command": "uv venv && uv pip install -r requirements.test.txt",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "pytest tests/",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Format & Lint Code",
      "type": "shell",
      "command": "ruff format . && ruff check .",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Run Type Checker",
      "type": "shell",
      "command": "mypy .",
      "group": "build",
      "problemMatcher": []
    }
  ]
}
